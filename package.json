    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint not configured'",
    "deploy": "npm run build && node scripts/deploy-pages.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "idb": "^8.0.3",
    "material-symbols": "^0.44.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
