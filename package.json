{
  "name": "kwanza-profit-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Progressive Web App local-first para registrar vendas de moeda estrangeira e acompanhar o Lucro Total em Kwanzas (AOA).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
